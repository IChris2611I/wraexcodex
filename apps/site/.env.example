# ============================================================
# LootReference — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Database (Supabase) ---
# Direct connection (use for migrations only — not for serverless/edge)
# DATABASE_URL_DIRECT="postgresql://postgres:[password]@db.rvifkvvtqkpfmttcsany.supabase.co:5432/postgres"
#
# Transaction pooler (use this for Next.js + Drizzle in serverless — port 6543)
DATABASE_URL="postgresql://postgres:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://rvifkvvtqkpfmttcsany.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_EUR15oz3sONLJbi_jISlrw_po6mgW-x"
# Get from: Supabase Dashboard → Settings → API → service_role (secret — never expose)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Clerk Auth ---
# Get from: dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Where to redirect after sign in/up
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
# Webhook secret for syncing users to DB
CLERK_WEBHOOK_SECRET="whsec_..."

# --- AI (Anthropic) ---
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# --- Upstash Redis (caching + rate limiting) ---
# Get from: console.upstash.com → Your DB → REST API
UPSTASH_REDIS_REST_URL="https://[id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="AX..."

# --- Meilisearch (search) ---
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_ADMIN_KEY="your-admin-key"
NEXT_PUBLIC_MEILISEARCH_URL="http://localhost:7700"
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY="your-search-only-key"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
