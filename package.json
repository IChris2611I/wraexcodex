{
  "name": "wraexcodex",
  "private": true,
  "version": "0.0.1",
  "description": "LootReference — The definitive Path of Exile 2 reference platform",
  "scripts": {
    "dev": "turbo dev --filter=@wraexcodex/site",
    "dev:bot": "turbo dev --filter=@wraexcodex/bot",
    "dev:jobs": "turbo dev --filter=@wraexcodex/jobs",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.2.0",
  "engines": {
    "node": ">=20",
    "bun": ">=1.2.0"
  }
}
